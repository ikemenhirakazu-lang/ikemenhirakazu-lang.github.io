---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2>
			<a href="/">
				<svg
					class="logo-paw"
					viewBox="0 0 24 24"
					width="20"
					height="20"
					aria-hidden="true"
				>
					<ellipse cx="7" cy="7.5" rx="2.4" ry="3" fill="var(--safety)"></ellipse>
					<ellipse cx="17" cy="7.5" rx="2.4" ry="3" fill="var(--safety)"></ellipse>
					<ellipse cx="3.2" cy="12.5" rx="2.1" ry="2.6" fill="var(--safety)"></ellipse>
					<ellipse cx="20.8" cy="12.5" rx="2.1" ry="2.6" fill="var(--safety)"></ellipse>
					<path
						d="M12 11c3.6 0 6.4 2.7 6.4 5.7 0 2.4-1.8 4.3-4.1 4.3-0.9 0-1.6-0.3-2.3-0.3s-1.4 0.3-2.3 0.3c-2.3 0-4.1-1.9-4.1-4.3C5.6 13.7 8.4 11 12 11z"
						fill="var(--safety)"></path>
				</svg>
				{SITE_TITLE}
			</a>
		</h2>
		<div class="internal-links">
			<HeaderLink href="/">ホーム</HeaderLink>
			<HeaderLink href="/blog">ブログ</HeaderLink>
			<HeaderLink href="/about">プロフィール</HeaderLink>
			<HeaderLink href="/privacy-policy">プライバシーポリシー</HeaderLink>
			<HeaderLink href="/contact">お問い合わせ</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: var(--card);
		border-bottom: 1px solid var(--line);
		position: relative;
	}
	/* 現場の安全テープ風ライン(このサイトの隠し印) */
	header::after {
		content: '';
		display: block;
		position: absolute;
		left: 0;
		right: 0;
		bottom: -6px;
		height: 6px;
		background: repeating-linear-gradient(
			-45deg,
			#2b2f36 0 10px,
			var(--safety) 10px 20px
		);
	}
	h2 {
		margin: 0;
		font-size: 1.15em;
		white-space: nowrap;
	}
	h2 a {
		display: inline-flex;
		align-items: center;
		gap: 0.35em;
		text-decoration: none;
		color: var(--ink);
		font-family: var(--font-display);
		font-weight: 800;
	}
	.logo-paw {
		flex-shrink: 0;
		transform: rotate(-12deg);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 0 0.5em;
	}
	.internal-links {
		display: flex;
		flex-wrap: wrap;
	}
	nav a {
		padding: 0.9em 0.5em;
		color: var(--ink);
		border-bottom: 4px solid transparent;
		text-decoration: none;
		font-size: 0.92em;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--safety);
	}
	nav a:hover {
		color: var(--link);
	}
	@media (max-width: 720px) {
		nav {
			justify-content: center;
			padding: 0.4em 0;
		}
		nav a {
			padding: 0.4em 0.5em;
		}
	}
</style>
