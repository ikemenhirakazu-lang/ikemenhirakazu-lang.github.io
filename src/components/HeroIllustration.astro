---
// ボスとジンとニックの仮イラスト(SVG)。
// ChatGPTで作った本番イラストが届いたら、この中身を <img> に置き換える。
---

<svg
	viewBox="0 0 400 300"
	role="img"
	aria-label="ボスと2匹の猫(ジンとニック)のイラスト"
>
	<!-- 背景 -->
	<rect x="0" y="0" width="400" height="300" rx="18" fill="#fff3cf"></rect>
	<!-- 床 -->
	<rect x="0" y="230" width="400" height="70" rx="18" fill="#f0e2b6"></rect>

	<!-- ボス -->
	<!-- 体 -->
	<path d="M130 230 q0 -55 70 -55 q70 0 70 55 z" fill="#3e5a78"></path>
	<!-- 顔 -->
	<circle cx="200" cy="130" r="52" fill="#f6d7b8"></circle>
	<!-- 髪(短髪) -->
	<path d="M152 118 q6 -42 48 -42 q42 0 48 42 q-10 -18 -48 -18 q-38 0 -48 18z" fill="#4a4038"></path>
	<!-- 眉 -->
	<rect x="172" y="116" width="18" height="5" rx="2.5" fill="#4a4038"></rect>
	<rect x="210" y="116" width="18" height="5" rx="2.5" fill="#4a4038"></rect>
	<!-- 目(にっこり) -->
	<path d="M175 132 q6 6 12 0" stroke="#33302c" stroke-width="4" fill="none" stroke-linecap="round"></path>
	<path d="M213 132 q6 6 12 0" stroke="#33302c" stroke-width="4" fill="none" stroke-linecap="round"></path>
	<!-- 口(お調子者の笑い) -->
	<path d="M186 152 q14 14 28 0" stroke="#33302c" stroke-width="4" fill="none" stroke-linecap="round"></path>

	<!-- 猫1: ジン(グレー) 左 -->
	<g>
		<ellipse cx="85" cy="238" rx="34" ry="26" fill="#9aa5ad"></ellipse>
		<circle cx="85" cy="200" r="24" fill="#9aa5ad"></circle>
		<path d="M67 188 l-4 -16 l14 8 z" fill="#9aa5ad"></path>
		<path d="M103 188 l4 -16 l-14 8 z" fill="#9aa5ad"></path>
		<path d="M69 176 l-2 -8 l7 4 z" fill="#e8a5a5"></path>
		<path d="M101 176 l2 -8 l-7 4 z" fill="#e8a5a5"></path>
		<circle cx="77" cy="198" r="3" fill="#33302c"></circle>
		<circle cx="93" cy="198" r="3" fill="#33302c"></circle>
		<path d="M81 206 q4 4 8 0" stroke="#33302c" stroke-width="2.5" fill="none" stroke-linecap="round"></path>
		<path d="M51 238 q-14 -6 -8 -22" stroke="#9aa5ad" stroke-width="9" fill="none" stroke-linecap="round"></path>
	</g>

	<!-- 猫2: ニック(茶トラ) 右 -->
	<g>
		<ellipse cx="315" cy="238" rx="34" ry="26" fill="#d89a5b"></ellipse>
		<circle cx="315" cy="200" r="24" fill="#d89a5b"></circle>
		<path d="M297 188 l-4 -16 l14 8 z" fill="#d89a5b"></path>
		<path d="M333 188 l4 -16 l-14 8 z" fill="#d89a5b"></path>
		<path d="M299 176 l-2 -8 l7 4 z" fill="#e8a5a5"></path>
		<path d="M331 176 l2 -8 l-7 4 z" fill="#e8a5a5"></path>
		<circle cx="307" cy="198" r="3" fill="#33302c"></circle>
		<circle cx="323" cy="198" r="3" fill="#33302c"></circle>
		<path d="M311 206 q4 4 8 0" stroke="#33302c" stroke-width="2.5" fill="none" stroke-linecap="round"></path>
		<path d="M349 238 q14 -6 8 -22" stroke="#d89a5b" stroke-width="9" fill="none" stroke-linecap="round"></path>
		<!-- トラ縞 -->
		<path d="M303 182 q4 3 8 0" stroke="#b97c3f" stroke-width="3" fill="none"></path>
		<path d="M319 182 q4 3 8 0" stroke="#b97c3f" stroke-width="3" fill="none"></path>
	</g>

	<!-- 肉球スタンプ -->
	<g fill="#e9c46a" opacity="0.8">
		<circle cx="42" cy="66" r="7"></circle>
		<circle cx="32" cy="52" r="3.4"></circle>
		<circle cx="42" cy="48" r="3.4"></circle>
		<circle cx="52" cy="52" r="3.4"></circle>
	</g>
	<g fill="#e9c46a" opacity="0.8">
		<circle cx="358" cy="86" r="7"></circle>
		<circle cx="348" cy="72" r="3.4"></circle>
		<circle cx="358" cy="68" r="3.4"></circle>
		<circle cx="368" cy="72" r="3.4"></circle>
	</g>
</svg>

<style>
	svg {
		width: 100%;
		height: auto;
		display: block;
	}
</style>
